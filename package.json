{
  "name": "cypress-cucumber-starter",
  "version": "1.0.0",
  "description": "This is a starter tesmplate for cypress with cucumber framework",
  "keywords": [
    "Cypress",
    "cucumber",
    "framework"
  ],
  "homepage": "https://github.com/Emuohwo/cypress-cucumber-starter#readme",
  "bugs": {
    "url": "https://github.com/Emuohwo/cypress-cucumber-starter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emuohwo/cypress-cucumber-starter.git"
  },
  "license": "ISC",
  "author": "Isaac Warri",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test:smoke": "npx cypress run --env TAGS='@smoke'",
    "test:regression": "npx cypress run --env TAGS='@regression'",
    "test:not-smoke": "npx cypress run --env TAGS='not @smoke'"
  },
  "devDependencies": {
    "cypress": "^15.16.0",
    "cypress-cucumber-preprocessor": "^4.3.1",
    "dotenv": "^17.4.2"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": true,
    "step_definitions": "cypress/e2e/pages"
  }
}
